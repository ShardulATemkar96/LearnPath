{
  "ConnectionStrings": {
    "DefaultConnection": "YOUR_PRODUCTION_CONNECTION_STRING"
  },
  "JwtSettings": {
    "Secret": "YOUR_PRODUCTION_SECRET_MIN_32_CHARS",
    "Issuer": "LearnPathAPI",
    "Audience": "LearnPathClient",
    "ExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 7
  },
  "AllowedOrigins": "https://your-frontend-domain.com",
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
